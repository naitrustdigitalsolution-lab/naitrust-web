# Frontend data mode options:
# VITE_APP_MODE=mock   # frontend-only; uses src/mocks
# VITE_APP_MODE=dev    # integration environment
# VITE_APP_MODE=prod   # production environment
VITE_APP_MODE=mock

# Page phase options:
# VITE_PAGE_PHASE=app          # default product home screen
# VITE_PAGE_PHASE=coming-soon  # waitlist coming-soon screen
# VITE_PAGE_PHASE=be-back      # temporary status screen
VITE_PAGE_PHASE=app

# Base URL of the Naitrust API (backend). Leave empty for same-origin.
# Public submissions (waitlist, contact, feedback) and all app data go to the backend.
VITE_API_BASE_URL=
